{
  "name": "@gwop/sdk",
  "version": "0.2.2",
  "description": "The commerce API for teams selling to AI agents.",
  "author": "Gwop <hello@gwop.io>",
  "license": "MIT",
  "homepage": "https://docs.gwop.io",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gwop-io/gwop-node.git"
  },
  "keywords": [
    "gwop",
    "usdc",
    "x402",
    "ai-agents",
    "payments",
    "commerce"
  ],
  "type": "module",
  "main": "./esm/index.js",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./esm/index.d.ts",
      "default": "./esm/index.js"
    },
    "./package.json": "./package.json",
    "./types": {
      "source": "./src/types/index.ts",
      "types": "./esm/types/index.d.ts",
      "default": "./esm/types/index.js"
    },
    "./models/errors": {
      "source": "./src/models/errors/index.ts",
      "types": "./esm/models/errors/index.d.ts",
      "default": "./esm/models/errors/index.js"
    },
    "./models": {
      "source": "./src/models/index.ts",
      "types": "./esm/models/index.d.ts",
      "default": "./esm/models/index.js"
    },
    "./models/operations": {
      "source": "./src/models/operations/index.ts",
      "types": "./esm/models/operations/index.d.ts",
      "default": "./esm/models/operations/index.js"
    },
    "./models/webhooks": {
      "source": "./src/models/webhooks/index.ts",
      "types": "./esm/models/webhooks/index.d.ts",
      "default": "./esm/models/webhooks/index.js"
    },
    "./*.js": {
      "source": "./src/*.ts",
      "types": "./esm/*.d.ts",
      "default": "./esm/*.js"
    },
    "./*": {
      "source": "./src/*.ts",
      "types": "./esm/*.d.ts",
      "default": "./esm/*.js"
    }
  },
  "files": [
    "esm/",
    "src/",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsgo",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format:check": "biome format .",
    "format": "biome format --write .",
    "test": "tsx tests/01-invoices-create.ts && tsx tests/02-invoices-list.ts && tsx tests/03-invoices-get.ts && tsx tests/04-invoices-cancel.ts && tsx tests/05-auth-create-intent.ts && tsx tests/06-auth-exchange.ts && tsx tests/07-auth-jwks.ts && tsx tests/08-auth-sessions.ts && tsx tests/09-webhooks.ts && tsx tests/10-errors.ts && tsx tests/11-webhook-secret-env.ts",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "@typescript/native-preview": "7.0.0-dev.20260302.1",
    "tsx": "^4.21.0",
    "typescript": "~5.8.3"
  },
  "dependencies": {
    "zod": "^3.25.65 || ^4.0.0"
  }
}
